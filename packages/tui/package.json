{
    "name": "@portable-devshell/tui",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./testing": {
            "types": "./dist/testing.d.ts",
            "default": "./dist/testing.js"
        }
    },
    "files": [
        "dist"
    ],
    "dependencies": {
        "@portable-devshell/shared": "workspace:*",
        "ink": "^5.2.1",
        "react": "^18.3.1",
        "string-argv": "^0.3.2",
        "string-width": "^7.2.0"
    },
    "scripts": {
        "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -b --force",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "test": "pnpm --filter @portable-devshell/control build && pnpm run build && node --import ../mcp/test/RegisterWorkspacePackages.mjs --test --test-concurrency=1 test/unit/*.test.ts test/integration/*.test.ts"
    }
}
