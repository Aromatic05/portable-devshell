{
    "name": "@portable-devshell/cli",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
        "devshell": "./dist/CliMain.js"
    },
    "dependencies": {
        "@portable-devshell/control": "workspace:*",
        "@portable-devshell/shared": "workspace:*",
        "@portable-devshell/tui": "workspace:*"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -b --force",
        "typecheck": "tsc --noEmit -p ../../tsconfig.typecheck.json",
        "test": "node ../../test/RunPackageTests.mjs --loader ../mcp/test/RegisterWorkspacePackages.mjs --concurrency 1 \"test/unit/*.test.ts\" \"test/integration/*.test.ts\""
    }
}
