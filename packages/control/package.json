{
    "name": "@portable-devshell/control",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "dependencies": {
        "@portable-devshell/core": "workspace:*",
        "@portable-devshell/mcp": "workspace:*",
        "@portable-devshell/shared": "workspace:*",
        "hash-wasm": "^4.12.0",
        "smol-toml": "1.7.0",
        "tar-stream": "^3.2.0",
        "ws": "8.21.0"
    },
    "scripts": {
        "build": "tsc -b --force",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "test": "tsc -b --force && node --import ../mcp/test/RegisterWorkspacePackages.mjs --test test/unit/*.test.ts test/integration/*.test.ts"
    },
    "devDependencies": {
        "@types/tar-stream": "^3.1.4",
        "@types/ws": "8.18.1"
    }
}
