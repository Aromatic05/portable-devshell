{
    "name": "@portable-devshell/control",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./testing": {
            "types": "./dist/testing.d.ts",
            "default": "./dist/testing.js"
        }
    },
    "files": [
        "dist"
    ],
    "dependencies": {
        "@portable-devshell/core": "workspace:*",
        "@portable-devshell/mcp": "workspace:*",
        "@portable-devshell/shared": "workspace:*",
        "hash-wasm": "^4.12.0",
        "smol-toml": "1.7.0",
        "tar-stream": "^3.2.0",
        "ws": "8.21.0"
    },
    "scripts": {
        "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -b --force",
        "typecheck": "tsc --noEmit -p ../../tsconfig.typecheck.json",
        "test": "node ../../test/RunPackageTests.mjs --loader ../mcp/test/RegisterWorkspacePackages.mjs --concurrency 1 \"test/unit/*.test.ts\" \"test/integration/*.test.ts\""
    },
    "devDependencies": {
        "@types/tar-stream": "^3.1.4",
        "@types/ws": "8.18.1"
    }
}
