{
    "name": "@portable-devshell/shared",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -b --force",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "test": "pnpm run build && node --import ./test/RegisterWorkspacePackages.mjs --test test/integration/*.test.mjs test/unit/runtime/*.test.ts test/unit/transport/*.test.ts"
    }
}
