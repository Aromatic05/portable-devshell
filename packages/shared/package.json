{
    "name": "@portable-devshell/shared",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./transport/frame": {
            "types": "./dist/transport/Frame.d.ts",
            "default": "./dist/transport/Frame.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -b --force",
        "typecheck": "tsc --noEmit -p ../../tsconfig.typecheck.json",
        "test": "node ../../test/RunPackageTests.mjs --loader ./test/RegisterWorkspacePackages.mjs \"test/integration/*.test.mjs\" \"test/unit/config/*.test.ts\" \"test/unit/runtime/*.test.ts\" \"test/unit/schema/*.test.ts\" \"test/unit/transport/*.test.ts\""
    }
}
