{
    "name": "@portable-devshell/core",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./testing": {
            "types": "./dist/testing.d.ts",
            "default": "./dist/testing.js"
        }
    },
    "files": [
        "dist"
    ],
    "dependencies": {
        "@portable-devshell/shared": "workspace:*",
        "ajv": "8.20.0",
        "string-argv": "^0.3.2"
    },
    "scripts": {
        "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -b --force",
        "typecheck": "tsc --noEmit -p ../../tsconfig.typecheck.json",
        "test": "node ../../test/RunPackageTests.mjs --loader ./test/RegisterWorkspacePackages.mjs --concurrency 1 \"test/unit/*.test.ts\" \"test/integration/*.test.ts\""
    }
}
