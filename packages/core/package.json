{
    "name": "@portable-devshell/core",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "dependencies": {
        "@portable-devshell/shared": "workspace:*"
    },
    "scripts": {
        "build": "tsc -b",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "test": "tsc -b && node --import ./test/RegisterWorkspacePackages.mjs --test test/unit/*.test.ts test/integration/*.test.ts"
    }
}
