{
    "name": "portable-devshell",
    "version": "0.4.7",
    "private": true,
    "packageManager": "pnpm@10.13.1",
    "engines": {
        "node": ">=24"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "node-pty"
        ]
    },
    "scripts": {
        "dev": "node ./scripts/dev.mjs",
        "build": "pnpm -r --filter \"./packages/*\" build",
        "build:worker": "node ./scripts/build-worker.mjs",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "version:set": "node ./scripts/version-state.mjs set",
        "version:check": "node ./scripts/version-state.mjs check-development",
        "test": "pnpm test:release-layout && pnpm -r --workspace-concurrency=1 --filter \"./packages/*\" test",
        "typecheck": "pnpm typecheck:source && pnpm typecheck:test",
        "install:local": "node ./scripts/install-local.mjs",
        "package:app": "node ./scripts/package-app.mjs",
        "smoke:package": "node ./scripts/smoke-package.mjs",
        "smoke:install-release": "node ./scripts/smoke-install-release.mjs",
        "test:release-layout": "node --test scripts/application-layout.test.mjs scripts/build-output.test.mjs scripts/build-worker.test.mjs scripts/install-release.test.mjs scripts/package-app.test.mjs scripts/verify-release-ci.test.mjs scripts/version-state.test.mjs",
        "test:prepare": "cargo build --locked -p devshell-worker",
        "test:prepared": "pnpm test:prepare && pnpm test",
        "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
        "acceptance": "node ./acceptance/run-final-acceptance.mjs",
        "acceptance:typecheck": "node ./acceptance/run-typecheck.mjs",
        "acceptance:test": "node ./acceptance/run-unit-tests.mjs",
        "acceptance:worker": "node ./acceptance/run-real-worker-smoke.mjs",
        "acceptance:mcp": "node ./acceptance/run-mcp-smoke.mjs",
        "typecheck:source": "tsc --noEmit -p tsconfig.typecheck.json",
        "test:worker:tmux": "cargo test --locked -p devshell-worker --test tmux_tools_contract -- --ignored"
    },
    "devDependencies": {
        "@types/react": "^18.3.11",
        "@types/node": "^24.0.0",
        "@eslint/js": "^9.31.0",
        "eslint": "^9.31.0",
        "globals": "^16.3.0",
        "prettier": "^3.6.2",
        "tsx": "^4.8.1",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.37.0"
    },
    "type": "module"
}
