{
    "name": "portable-devshell",
    "version": "0.2.0",
    "private": true,
    "packageManager": "pnpm@10.13.1",
    "scripts": {
        "dev": "node ./scripts/dev.mjs",
        "build": "cargo build -p devshell-worker --manifest-path ./Cargo.toml && node ./scripts/build-worker.mjs --copy-only && tsc -b",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "test": "pnpm -r --filter './packages/*' test",
        "typecheck": "pnpm -r --filter './packages/*' typecheck"
    },
    "devDependencies": {
        "@types/node": "^24.0.0",
        "@eslint/js": "^9.31.0",
        "eslint": "^9.31.0",
        "globals": "^16.3.0",
        "prettier": "^3.6.2",
        "tsx": "^4.8.1",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.37.0"
    }
}
