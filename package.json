{
    "name": "portable-devshell",
    "version": "0.4.1",
    "private": true,
    "packageManager": "pnpm@10.13.1",
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "dev": "node ./scripts/dev.mjs",
        "build": "tsc -b",
        "build:worker:debug": "node ./scripts/build-worker.mjs",
        "build:worker:debug:linux-x64": "node ./scripts/build-worker.mjs --target linux-x64",
        "build:worker:debug:linux-arm64": "node ./scripts/build-worker.mjs --target linux-arm64",
        "build:worker:debug:darwin-x64": "node ./scripts/build-worker.mjs --target darwin-x64",
        "build:worker:debug:darwin-arm64": "node ./scripts/build-worker.mjs --target darwin-arm64",
        "build:worker:debug:windows-x64": "node ./scripts/build-worker.mjs --target windows-x64",
        "build:worker:debug:windows-arm64": "node ./scripts/build-worker.mjs --target windows-arm64",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "test": "pnpm -r --filter './packages/*' test",
        "typecheck": "pnpm -r --filter './packages/*' typecheck",
        "install:local": "node ./scripts/install-local.mjs",
        "package:app": "node ./scripts/package-app.mjs",
        "smoke:package": "node ./scripts/smoke-package.mjs"
    },
    "devDependencies": {
        "@types/react": "^18.3.11",
        "@types/node": "^24.0.0",
        "@eslint/js": "^9.31.0",
        "eslint": "^9.31.0",
        "globals": "^16.3.0",
        "prettier": "^3.6.2",
        "tsx": "^4.8.1",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.37.0"
    }
}
